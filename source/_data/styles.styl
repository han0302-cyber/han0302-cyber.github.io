// 讓每個外部連結各自獨佔一列並置中（覆蓋 Gemini 布景的 flex 兩欄排版）
.links-of-author {
  flex-direction: column;
}

.links-of-author-item {
  width: 100% !important;
  text-align: center;
}

.links-of-author-item a {
  display: inline-block;
  margin-right: 0;
}

// 頁尾版權聲明的 CC 圖示
.cc-license {
  margin-top: 8px;
}

.cc-license .fab {
  margin: 0 1px;
}
