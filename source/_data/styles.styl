.links-of-author-item {
  width: 100% !important;
}

.post-body blockquote {
  border-radius: 6px;
  padding: 10px 16px;
}

.post-body blockquote.callout-info {
  background: rgba(66, 135, 245, 0.12);
  border-left-color: #4287f5;
}

.post-body blockquote.callout-tip {
  background: rgba(46, 160, 67, 0.12);
  border-left-color: #2ea043;
}

.post-body blockquote.callout-note {
  background: rgba(120, 120, 130, 0.14);
  border-left-color: #787882;
}

.post-body blockquote.callout-warning {
  background: rgba(230, 180, 30, 0.16);
  border-left-color: #e6b41e;
}

.post-body blockquote.callout-question {
  background: rgba(230, 70, 70, 0.12);
  border-left-color: #e64646;
}
